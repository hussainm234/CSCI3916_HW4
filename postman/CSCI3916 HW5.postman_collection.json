      "name": "Get Top Rated Movies (reviews=true)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.test('Returns movies sorted by avgRating', function() {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(json.success).to.be.true;",
              "  pm.expect(json.movies).to.be.an('array');",
              "});",
              "if (json.movies && json.movies.length > 0) {",
              "  pm.collectionVariables.set('movieTitle', json.movies[0].title);",
              "  console.log('Top movie:', json.movies[0].title, '| avgRating:', json.movies[0].avgRating);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
