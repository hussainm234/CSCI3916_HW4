    {
      "name": "Get a Movies from DB",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.movies && jsonData.movies.length > 0) {",
              "  pm.collectionVariables.set('movie_title', jsonData.movies[0].title);",
              "  pm.collectionVariables.set('movie_id', jsonData.movies[0]._id);",
              "  console.log('Movie title saved:', jsonData.movies[0].title);",
              "  console.log('Movie ID saved:', jsonData.movies[0]._id);",
              "}",
              "",
              "pm.test('Get all movies successful', function () {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(pm.response.code).to.equal(200);",
              "  pm.expect(jsonData.movies).to.be.an('array');",
              "  pm.expect(jsonData.movies.length).to.be.above(0);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{jwt_token}}"
          }
        ],
        "url": {
          "raw": "https://csci3916-hw4-s598.onrender.com/movies",
